# Todoist API Configuration
# Copy this file to .env and fill in your actual values

# Your Todoist API access token
# Get it from: https://todoist.com/app/settings/integrations/developer
TODOIST_ACCESS_TOKEN=your_access_token_here

# Project IDs to test (comma-separated)
# Leave empty to fetch all projects
TEST_PROJECT_IDS=

# Section IDs to test (comma-separated)
# Leave empty to fetch all sections
TEST_SECTION_IDS=

# Label names to test (comma-separated)
TEST_LABELS=

# Debug mode (true/false)
DEBUG=true
